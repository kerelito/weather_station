{
  "name": "weather-station-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:simulator": "npm --prefix simulator run dev",
    "build": "npm --prefix backend run build && npm --prefix frontend run build && npm --prefix simulator run build",
    "db:migrate": "npm --prefix backend run prisma:migrate",
    "db:deploy": "npm --prefix backend run prisma:deploy",
    "db:seed": "npm --prefix backend run prisma:seed"
  }
}
